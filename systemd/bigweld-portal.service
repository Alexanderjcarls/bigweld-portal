[Unit]
Description=Bigweld DA Portal
After=network.target

[Service]
Type=simple
User=matrix_admin
Group=matrix_admin
WorkingDirectory=/datapool/bigweld-portal
Environment="PATH=/datapool/bigweld-portal/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="BIGWELD_PORTAL_ROOT=/datapool/bigweld-portal"
ExecStart=/datapool/bigweld-portal/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8884
Restart=on-failure
RestartSec=5
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
